AddDefaultCharset UTF-8
DirectoryIndex index.php
Options -Indexes

RewriteEngine On

# Force HTTPS after SSL certificate is enabled on the hosting.
RewriteCond %{HTTPS} !=on
RewriteCond %{HTTP:X-Forwarded-Proto} !https
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# Hide index.php and old ?page= links from the browser URL.
RewriteCond %{THE_REQUEST} \s/+index\.php[\s?] [NC]
RewriteRule ^index\.php$ / [R=301,L]

RewriteCond %{QUERY_STRING} ^page=table&id=([0-9]+)$ [NC]
RewriteRule ^$ /table/%1? [R=301,L]

RewriteCond %{QUERY_STRING} ^page=([a-zA-Z0-9_-]+)$ [NC]
RewriteRule ^$ /%1? [R=301,L]

# Keep real files and folders accessible.
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Clean POS routes.
RewriteRule ^table/([0-9]+)/?$ index.php?page=table&id=$1 [QSA,L]
RewriteRule ^(login|day|tables|products|history|reports|logout|print_order|print_final)/?$ index.php?page=$1 [QSA,L]
RewriteRule ^$ index.php?page=day [QSA,L]

<Files "config.php">
  Require all denied
</Files>
<Files "config.example.php">
  Require all denied
</Files>
